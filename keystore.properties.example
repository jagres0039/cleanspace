# Copy this file to "keystore.properties" (same folder) and fill in real values.
# keystore.properties is git-ignored and must NEVER be committed.
#
# Create a keystore once with:
#   keytool -genkey -v -keystore cleanspace-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias cleanspace
#
# Then point storeFile at that .jks path (absolute path is safest).

storeFile=/absolute/path/to/cleanspace-release.jks
storePassword=CHANGE_ME
keyAlias=cleanspace
keyPassword=CHANGE_ME
